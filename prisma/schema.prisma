generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum UploadStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  REVIEW_REQUIRED
  APPROVED
  REJECTED
  FAILED
  ARCHIVED
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditSource {
  API
  USER_ACTION
  AI_PIPELINE
  SYSTEM
  AUTH
}

enum NotificationCategory {
  POLICY
  RENEWAL
  CUSTOMER
  CLAIM
  ENDORSEMENT
  SERVICE_REQUEST
  TASK
  USER_MANAGEMENT
  SYSTEM
  APPROVAL
  ESCALATION
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum TaskType {
  CALL
  MEETING
  FOLLOW_UP
  RENEWAL
  COLLECTION
  CLAIM
  ENDORSEMENT
  SERVICE_REQUEST
  TEAM
  CUSTOM
}

enum TaskStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_INSURANCE_COMPANY
  WAITING_DOCUMENTS
  ESCALATED
  COMPLETED
  CANCELLED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  EMERGENCY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SENT_BACK
  CANCELLED
}

enum EscalationStatus {
  OPEN
  NOTIFIED
  RESOLVED
  CANCELLED
}

model Organization {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users         User[]
  policyRecords PolicyRecord[]
  uploadedFiles UploadedFile[]
  auditLogs     AuditLog[]
  customerProfiles CustomerProfile[]
  clientAccounts ClientAccount[]
  claims        Claim[]
  endorsements  Endorsement[]
  whatsAppTemplates WhatsAppTemplate[]
  whatsAppMessageQueues WhatsAppMessageQueue[]

  @@map("organizations")
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  action         String
  entityType     String        @map("entity_type")
  entityId       String?       @map("entity_id")
  severity       AuditSeverity @default(INFO)
  source         AuditSource   @default(USER_ACTION)
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  metadata       Json?
  userId         String?       @map("user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User?         @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model Notification {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String?              @map("organization_id") @db.Uuid
  userId         String?              @map("user_id") @db.Uuid
  createdById    String?              @map("created_by_id") @db.Uuid
  updatedById    String?              @map("updated_by_id") @db.Uuid
  category       NotificationCategory
  severity       NotificationSeverity @default(INFO)
  title          String
  message        String               @db.Text
  module         String
  recordId       String?              @map("record_id")
  recordLabel    String?              @map("record_label")
  actionUrl      String?              @map("action_url") @db.Text
  sourceKey      String               @unique @map("source_key")
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  reads          NotificationRead[]

  @@index([organizationId, createdAt])
  @@index([organizationId, category, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  readAt         DateTime     @default(now()) @map("read_at") @db.Timestamptz(6)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_reads")
}

model NotificationPreference {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  category       String
  inApp          Boolean  @default(true) @map("in_app")
  email          Boolean  @default(false)
  whatsapp       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, category])
  @@index([organizationId, userId])
  @@map("notification_preferences")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  createdById    String?      @map("created_by_id") @db.Uuid
  updatedById    String?      @map("updated_by_id") @db.Uuid
  title          String
  description    String?      @db.Text
  type           TaskType
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  module         String
  recordId       String?      @map("record_id")
  recordLabel    String?      @map("record_label")
  customerName   String?      @map("customer_name")
  customerMobile String?      @map("customer_mobile")
  policyNumber   String?      @map("policy_number")
  amount         Decimal?     @db.Decimal(14, 2)
  dueAt          DateTime?    @map("due_at") @db.Timestamptz(6)
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz(6)
  archivedAt     DateTime?    @map("archived_at") @db.Timestamptz(6)
  sourceKey      String?      @unique @map("source_key")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  assignments    TaskAssignment[]
  comments       TaskComment[]
  attachments    TaskAttachment[]
  reminders      Reminder[]

  @@index([organizationId, status, dueAt])
  @@index([organizationId, type, dueAt])
  @@index([userId, status, dueAt])
  @@index([module, recordId])
  @@map("tasks")
}

model TaskAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  taskId     String    @map("task_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  assignedBy String?   @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId, assignedAt])
  @@map("task_assignments")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url") @db.Text
  fileType  String?  @map("file_type")
  uploadedBy String? @map("uploaded_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_attachments")
}

model Reminder {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  taskId         String?  @map("task_id") @db.Uuid
  module         String
  recordId       String?  @map("record_id")
  title          String
  remindAt       DateTime @map("remind_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  sourceKey      String?  @unique @map("source_key")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  task           Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([organizationId, remindAt])
  @@index([userId, remindAt])
  @@map("reminders")
}

model CalendarEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  createdById    String?  @map("created_by_id") @db.Uuid
  updatedById    String?  @map("updated_by_id") @db.Uuid
  title          String
  description    String?  @db.Text
  eventType      String   @default("TASK") @map("event_type")
  module         String
  recordId       String?  @map("record_id")
  startsAt       DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime? @map("ends_at") @db.Timestamptz(6)
  location       String?
  sourceKey      String?  @unique @map("source_key")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([organizationId, startsAt])
  @@index([userId, startsAt])
  @@map("calendar_events")
}

model Approval {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String?        @map("organization_id") @db.Uuid
  requestedById  String?        @map("requested_by_id") @db.Uuid
  approverId     String?        @map("approver_id") @db.Uuid
  approvalType   String         @map("approval_type")
  module         String
  recordId       String?        @map("record_id")
  title          String
  status         ApprovalStatus @default(PENDING)
  decisionNote   String?        @map("decision_note") @db.Text
  decidedAt      DateTime?      @map("decided_at") @db.Timestamptz(6)
  sourceKey      String?        @unique @map("source_key")
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([organizationId, status, createdAt])
  @@index([approverId, status])
  @@map("approvals")
}

model Escalation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String?          @map("organization_id") @db.Uuid
  taskId         String?          @map("task_id") @db.Uuid
  assignedUserId String?          @map("assigned_user_id") @db.Uuid
  managerUserId  String?          @map("manager_user_id") @db.Uuid
  module         String
  recordId       String?          @map("record_id")
  reason         String           @db.Text
  status         EscalationStatus @default(OPEN)
  escalatedAt    DateTime         @default(now()) @map("escalated_at") @db.Timestamptz(6)
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz(6)
  sourceKey      String?          @unique @map("source_key")
  metadata       Json             @default("{}")

  @@index([organizationId, status, escalatedAt])
  @@index([assignedUserId, status])
  @@map("escalations")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  userRole       String?  @map("user_role")
  module         String
  recordId       String?  @map("record_id")
  recordLabel    String?  @map("record_label")
  action         String
  description    String?  @db.Text
  oldValue       Json?    @map("old_value")
  newValue       Json?    @map("new_value")
  ipAddress      String?  @map("ip_address")
  browser        String?
  device         String?
  sourceKey      String?  @unique @map("source_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, createdAt])
  @@index([module, recordId])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model CustomerProfile {
  id                  String       @id @default(uuid()) @db.Uuid
  name                String
  phone               String
  alternatePhone      String?      @map("alternate_phone")
  email               String?
  dob                 DateTime?    @map("dob") @db.Timestamptz(6)
  address             String?
  city                String?
  state               String?
  occupation          String?
  businessType        String?      @map("business_type")
  contactPersonName   String?      @map("contact_person_name")
  customerType        String       @default("New") @map("customer_type")
  assignedTo          String?      @map("assigned_to")
  referenceSource     String?      @map("reference_source")
  sourcePolicyId      String?      @map("source_policy_id") @db.Uuid
  sourcePolicyNumber  String?      @map("source_policy_number")
  sourcePolicyType    String?      @map("source_policy_type")
  sourceCompany       String?      @map("source_company")
  selectedLOBs        Json         @default("[]") @map("selected_lobs")
  lobDetails          Json         @default("{}") @map("lob_details")
  status              String       @default("New Lead")
  followUpDate        DateTime?    @map("follow_up_date") @db.Timestamptz(6)
  lastFollowUpDate    DateTime?    @map("last_follow_up_date") @db.Timestamptz(6)
  nextFollowUpDate    DateTime?    @map("next_follow_up_date") @db.Timestamptz(6)
  followUpRemark      String?      @map("follow_up_remark")
  followUpOutcome     String?      @map("follow_up_outcome")
  remarks             String?
  convertedToCustomer Boolean      @default(false) @map("converted_to_customer")
  convertedPolicyId   String?      @map("converted_policy_id") @db.Uuid
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz(6)

  organizationId      String?      @map("organization_id") @db.Uuid
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById         String?      @map("created_by_id") @db.Uuid
  createdBy           User?        @relation("CustomerProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?      @map("updated_by_id") @db.Uuid
  updatedBy           User?        @relation("CustomerProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  endorsements        Endorsement[]
  policies            PolicyRecord[]

  @@index([phone])
  @@index([sourcePolicyNumber])
  @@index([organizationId])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, status])
  @@index([organizationId, nextFollowUpDate])
  @@index([organizationId, createdAt])
  @@index([createdById, deletedAt, updatedAt])
  googleEmail         String?      @unique @map("google_email")

  @@index([phone, deletedAt])
  @@index([status, deletedAt])
  @@index([createdById])
  @@index([deletedAt])
  @@index([googleEmail])
  @@map("customer_profiles")
}

model ClientAccount {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  phone          String
  email          String?
  googleEmail    String?       @unique @map("google_email")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)

  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById    String?       @map("created_by_id") @db.Uuid
  createdBy      User?         @relation("ClientAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById    String?       @map("updated_by_id") @db.Uuid
  updatedBy      User?         @relation("ClientAccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([organizationId])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([createdById])
  @@index([deletedAt])
  @@index([googleEmail])
  @@map("client_accounts")
}

model PolicyRecord {
  id                      String             @id @db.Uuid
  savedAt                 DateTime           @default(now()) @map("saved_at") @db.Timestamptz(6)
  data                    Json
  pdfBytes                Bytes?             @map("pdf_bytes")
  pdfFileName             String?            @map("pdf_file_name")
  pdfMimeType             String?            @map("pdf_mime_type")
  sourceFile              String?            @map("source_file")
  rawText                 String?            @map("raw_text")
  detectedCompany         String?            @map("detected_company")
  detectedServiceCategory String?            @map("detected_service_category")
  detectedPolicyType      String?            @map("detected_policy_type")
  selectedCompany         String?            @map("selected_company")
  detectedBankSource      String?            @map("detected_bank_source")
  selectedBankSource      String?            @map("selected_bank_source")
  selectedServiceCategory String?            @map("selected_service_category")
  selectedPolicyType      String?            @map("selected_policy_type")
  confidenceScore         Float?             @map("confidence_score")
  extractedData           Json?              @map("extracted_data")
  reviewedData            Json?              @map("reviewed_data")
  extractionMethod        String?            @map("extraction_method")
  extractionQuality       Json?              @map("extraction_quality")
  extractionLog           Json?              @map("extraction_log")
  schemaVersion           Int?               @map("schema_version")
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  uploadedFileId          String?            @map("uploaded_file_id") @db.Uuid
  uploadedFile            UploadedFile?      @relation(fields: [uploadedFileId], references: [id])
  policySchemaId          String?            @map("policy_schema_id") @db.Uuid
  policySchema            PolicySchema?      @relation(fields: [policySchemaId], references: [id])
  
  organizationId          String?            @map("organization_id") @db.Uuid
  organization            Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById             String?            @map("created_by_id") @db.Uuid
  createdBy               User?              @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById             String?            @map("updated_by_id") @db.Uuid
  updatedBy               User?              @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  clientIdRequestId       String?            @map("client_id_request_id") @db.Uuid
  clientIdPending         Boolean            @default(false) @map("client_id_pending")
  clientIdStatus          String             @default("LINKED") @map("client_id_status")
  deletedById             String?            @map("deleted_by_id") @db.Uuid
  deletedBy               User?              @relation("PolicyDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedAt               DateTime?          @map("deleted_at") @db.Timestamptz(6)

  renewalStatus           String?            @default("ACTIVE") @map("renewal_status")
  previousPolicyId        String?            @map("previous_policy_id") @db.Uuid
  renewedPolicyId         String?            @map("renewed_policy_id") @db.Uuid
  renewalDate             DateTime?          @map("renewal_date") @db.Timestamptz(6)
  lostReason              String?            @map("lost_reason")
  isActivePolicy          Boolean            @default(true) @map("is_active_policy")
  customerPortfolioId     String?            @map("customer_portfolio_id") @db.Uuid
  customerPortfolio       CustomerProfile?   @relation(fields: [customerPortfolioId], references: [id], onDelete: SetNull)
  contactPersonName       String?            @map("contact_person_name")
  contactPersonMobile     String?            @map("contact_person_mobile")
  contactPersonEmail      String?            @map("contact_person_email")
  renewalRecipientName    String?            @map("renewal_recipient_name")
  renewalRecipientMobile  String?            @map("renewal_recipient_mobile")
  renewalRecipientEmail   String?            @map("renewal_recipient_email")
  endorsements            Endorsement[]

  @@index([savedAt])
  @@index([uploadedFileId])
  @@index([policySchemaId])
  @@index([organizationId])
  @@index([organizationId, deletedAt, savedAt])
  @@index([organizationId, deletedAt, isActivePolicy])
  @@index([organizationId, renewalStatus])
  @@index([organizationId, isActivePolicy, renewalStatus])
  @@index([organizationId, customerPortfolioId])
  @@index([organizationId, renewalRecipientMobile])
  @@index([createdById, deletedAt, savedAt])
  @@index([clientIdRequestId])
  @@index([organizationId, clientIdPending])
  @@index([organizationId, clientIdStatus])
  @@index([selectedCompany])
  @@index([selectedPolicyType])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([createdById])
  @@map("pdf_records")
}

model BankSource {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique
  aliases   Json         @default("[]")
  active    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  schemas   PolicySchema[]
  uploads   UploadedFile[] @relation("DetectedBankSource")

  @@map("bank_sources")
}

model InsuranceCompany {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  aliases     Json         @default("[]")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  categories  PolicyType[]
  schemas     PolicySchema[]
  uploads     UploadedFile[] @relation("DetectedCompany")

  @@map("insurance_companies")
}

model ServiceCategory {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  aliases     Json         @default("[]")
  keywords    Json         @default("[]")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  policyTypes PolicyType[]
  schemas     PolicySchema[]
  uploads     UploadedFile[] @relation("DetectedCategory")

  @@map("service_categories")
}

model PolicyType {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  aliases            Json               @default("[]")
  keywords           Json               @default("[]")
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  insuranceCompanyId String?            @map("insurance_company_id") @db.Uuid
  serviceCategoryId  String             @map("service_category_id") @db.Uuid
  insuranceCompany   InsuranceCompany?  @relation(fields: [insuranceCompanyId], references: [id])
  serviceCategory    ServiceCategory    @relation(fields: [serviceCategoryId], references: [id])
  schemas            PolicySchema[]
  uploads            UploadedFile[]     @relation("DetectedPolicyType")

  @@unique([name, insuranceCompanyId, serviceCategoryId])
  @@map("policy_types")
}

model PolicySchema {
  id           String            @id @default(uuid()) @db.Uuid
  policyTypeId String            @map("policy_type_id") @db.Uuid
  bankSourceId String?           @map("bank_source_id") @db.Uuid
  insuranceCompanyId String?     @map("insurance_company_id") @db.Uuid
  serviceCategoryId String?      @map("service_category_id") @db.Uuid
  version      Int               @default(1)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  bankSource   BankSource?       @relation(fields: [bankSourceId], references: [id])
  insuranceCompany InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  serviceCategory ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  policyType   PolicyType        @relation(fields: [policyTypeId], references: [id])
  fields       FieldDefinition[]
  records      PolicyRecord[]

  @@unique([policyTypeId, version])
  @@map("policy_schemas")
}

model FieldDefinition {
  id             String       @id @default(uuid()) @db.Uuid
  policySchemaId String       @map("policy_schema_id") @db.Uuid
  key            String
  label          String
  fieldType      String       @map("field_type")
  required       Boolean      @default(false)
  options        Json         @default("[]")
  aliases        Json         @default("[]")
  regexPattern    String?      @map("regex_pattern")
  section         String?
  active          Boolean      @default(true)
  order          Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  policySchema   PolicySchema @relation(fields: [policySchemaId], references: [id], onDelete: Cascade)

  @@unique([policySchemaId, key])
  @@map("field_definitions")
}

model UploadedFile {
  id                         String             @id @default(uuid()) @db.Uuid
  sourceFile                 String             @map("source_file")
  mimeType                   String?            @map("mime_type")
  sizeBytes                  Int?               @map("size_bytes")
  pdfBytes                   Bytes?             @map("pdf_bytes")
  rawText                    String?            @map("raw_text")
  extractionMethod           String?            @map("extraction_method")
  status                     UploadStatus       @default(UPLOADED)
  detectedBankSourceId       String?            @map("detected_bank_source_id") @db.Uuid
  detectedCompanyId          String?            @map("detected_company_id") @db.Uuid
  detectedServiceCategoryId  String?            @map("detected_service_category_id") @db.Uuid
  detectedPolicyTypeId       String?            @map("detected_policy_type_id") @db.Uuid
  detectedBankSourceName     String?            @map("detected_bank_source_name")
  detectedCompanyName        String?            @map("detected_company_name")
  detectedServiceCategoryName String?           @map("detected_service_category_name")
  detectedPolicyTypeName     String?            @map("detected_policy_type_name")
  confidenceScore            Float?             @map("confidence_score")
  extractedData              Json?              @map("extracted_data")
  extractionQuality           Json?              @map("extraction_quality")
  extractionLog               Json?              @map("extraction_log")
  schemaFallbackLevel         String?            @map("schema_fallback_level")
  schemaVersion              Int?               @map("schema_version")
  errorMessage               String?            @map("error_message")
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  detectedBankSource         BankSource?        @relation("DetectedBankSource", fields: [detectedBankSourceId], references: [id])
  detectedCompany            InsuranceCompany?  @relation("DetectedCompany", fields: [detectedCompanyId], references: [id])
  detectedServiceCategory    ServiceCategory?   @relation("DetectedCategory", fields: [detectedServiceCategoryId], references: [id])
  detectedPolicyType         PolicyType?        @relation("DetectedPolicyType", fields: [detectedPolicyTypeId], references: [id])
  policyRecords              PolicyRecord[]
  endorsements               Endorsement[]
  
  organizationId             String?            @map("organization_id") @db.Uuid
  organization               Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById                String?            @map("created_by_id") @db.Uuid
  createdBy                  User?              @relation("UploadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById                String?            @map("updated_by_id") @db.Uuid
  updatedBy                  User?              @relation("UploadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById                String?            @map("deleted_by_id") @db.Uuid
  deletedBy                  User?              @relation("UploadDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedAt                  DateTime?          @map("deleted_at") @db.Timestamptz(6)

  storageProvider            String?            @map("storage_provider")
  storagePath                String?            @map("storage_path")
  fileHash                   String?            @map("file_hash")
  checksum                   String?
  fileSize                   Int?               @map("file_size")
  storageMetadata            Json?              @map("storage_metadata")

  @@index([createdAt])
  @@index([status])
  @@index([organizationId])
  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([createdById, deletedAt, createdAt])
  @@index([deletedAt])
  @@index([createdById])
  @@map("uploaded_files")
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  password       String
  name           String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  role           UserRole       @default(AGENT)
  organizationId String?        @map("organization_id") @db.Uuid
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  assignedLOBs   Json           @default("[]") @map("assigned_lobs")
  
  createdPolicies PolicyRecord[] @relation("PolicyCreatedBy")
  updatedPolicies PolicyRecord[] @relation("PolicyUpdatedBy")
  deletedPolicies PolicyRecord[] @relation("PolicyDeletedBy")
  
  createdUploads UploadedFile[] @relation("UploadCreatedBy")
  updatedUploads UploadedFile[] @relation("UploadUpdatedBy")
  deletedUploads UploadedFile[] @relation("UploadDeletedBy")

  auditLogs      AuditLog[]
  createdCustomerProfiles CustomerProfile[] @relation("CustomerProfileCreatedBy")
  updatedCustomerProfiles CustomerProfile[] @relation("CustomerProfileUpdatedBy")
  createdClientAccounts ClientAccount[] @relation("ClientAccountCreatedBy")
  updatedClientAccounts ClientAccount[] @relation("ClientAccountUpdatedBy")
  createdClaims Claim[] @relation("ClaimCreatedBy")
  updatedClaims Claim[] @relation("ClaimUpdatedBy")
  deletedClaims Claim[] @relation("ClaimDeletedBy")
  claimRemarks ClaimRemark[] @relation("ClaimRemarkCreatedBy")
  claimDocuments ClaimDocument[] @relation("ClaimDocumentUploadedBy")
  createdEndorsements Endorsement[] @relation("EndorsementCreatedBy")
  updatedEndorsements Endorsement[] @relation("EndorsementUpdatedBy")
  deletedEndorsements Endorsement[] @relation("EndorsementDeletedBy")
  endorsementDocuments EndorsementDocument[] @relation("EndorsementDocumentUploadedBy")

  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Endorsement {
  id                            String      @id @default(uuid()) @db.Uuid
  endorsementNo                 String      @map("endorsement_no")
  policyNo                      String?     @map("policy_no")
  insuredName                   String      @map("insured_name")
  customerName                  String?     @map("customer_name")
  mailingAddress                String?     @map("mailing_address") @db.Text
  insuranceCompany              String?     @map("insurance_company")
  policyType                    String?     @map("policy_type")
  endorsementType               String      @map("endorsement_type")
  endorsementDate               DateTime    @map("endorsement_date") @db.Timestamptz(6)
  effectiveDate                 DateTime?   @map("effective_date") @db.Timestamptz(6)
  effectiveFrom                 DateTime?   @map("effective_from") @db.Timestamptz(6)
  effectiveTo                   DateTime?   @map("effective_to") @db.Timestamptz(6)
  customerRequestDate           DateTime?   @map("customer_request_date") @db.Timestamptz(6)
  dateOfIssue                   DateTime?   @map("date_of_issue") @db.Timestamptz(6)
  issuedOffice                  String?     @map("issued_office")
  financerDetails               String?     @map("financer_details") @db.Text
  premium                       String?
  policyStartDate               DateTime?   @map("policy_start_date") @db.Timestamptz(6)
  policyExpiryDate              DateTime?   @map("policy_expiry_date") @db.Timestamptz(6)
  sumInsured                    String?     @map("sum_insured")
  address                       String?
  warehouseDetails              String?     @map("warehouse_details") @db.Text
  oldValues                     Json        @default("{}") @map("old_values")
  newValues                     Json        @default("{}") @map("new_values")
  extractedPolicyData           Json        @default("{}") @map("extracted_policy_data")
  finalReviewedData             Json        @default("{}") @map("final_reviewed_data")
  rawExtractedData              Json        @default("{}") @map("raw_extracted_data")
  description                   String?     @db.Text
  internalRemark                String?     @map("internal_remark") @db.Text
  customerRemark                String?     @map("customer_remark") @db.Text
  remark                        String?     @db.Text
  generatedLetterPdfUrl         String?     @map("generated_letter_pdf_url") @db.Text
  generatedLetterFileName       String?     @map("generated_letter_file_name")
  insuranceCompanyLetterPdfUrl  String?     @map("insurance_company_letter_pdf_url") @db.Text
  insuranceCompanyLetterFileName String?    @map("insurance_company_letter_file_name")
  impacts                       Json        @default("[]")
  gstPart                       Decimal?    @map("gst_part") @db.Decimal(14, 2)
  stampDuty                     Decimal?    @map("stamp_duty") @db.Decimal(14, 2)
  cancellationReason            String?     @map("cancellation_reason") @db.Text
  status                        String      @default("Draft")
  creationMethod                String?     @map("creation_method")
  premiumChangeType             String?     @map("premium_change_type")
  premiumChangeAmount           Decimal?    @map("premium_change_amount") @db.Decimal(14, 2)
  sumInsuredChangeType          String?     @map("sum_insured_change_type")
  sumInsuredChangeAmount        Decimal?    @map("sum_insured_change_amount") @db.Decimal(14, 2)
  paymentReceived               Boolean     @default(false) @map("payment_received")
  paymentAmount                 Decimal?    @map("payment_amount") @db.Decimal(14, 2)
  paymentDate                   DateTime?   @map("payment_date") @db.Timestamptz(6)
  paymentMode                   String?     @map("payment_mode")
  transactionReference          String?     @map("transaction_reference")
  documentStatus                String      @default("AWAITING_UPLOAD") @map("document_status")
  verifiedById                  String?     @map("verified_by_id") @db.Uuid
  verifiedAt                    DateTime?   @map("verified_at") @db.Timestamptz(6)
  createdAt                     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                     DateTime?   @map("deleted_at") @db.Timestamptz(6)

  policyId                      String?     @map("policy_id") @db.Uuid
  policy                        PolicyRecord? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  customerId                    String?     @map("customer_id") @db.Uuid
  customer                      CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  uploadedPolicyFileId          String?     @map("uploaded_policy_file_id") @db.Uuid
  uploadedPolicyFile            UploadedFile? @relation(fields: [uploadedPolicyFileId], references: [id], onDelete: SetNull)
  organizationId                String?     @map("organization_id") @db.Uuid
  organization                  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById                   String?     @map("created_by_id") @db.Uuid
  createdBy                     User?       @relation("EndorsementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById                   String?     @map("updated_by_id") @db.Uuid
  updatedBy                     User?       @relation("EndorsementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById                   String?     @map("deleted_by_id") @db.Uuid
  deletedBy                     User?       @relation("EndorsementDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  documents                     EndorsementDocument[]

  @@unique([organizationId, endorsementNo])
  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, status])
  @@index([policyNo])
  @@index([endorsementNo])
  @@index([insuranceCompany])
  @@index([policyId])
  @@index([customerId])
  @@map("endorsements")
}

model EndorsementDocument {
  id             String      @id @default(uuid()) @db.Uuid
  endorsementId  String      @map("endorsement_id") @db.Uuid
  endorsement    Endorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  documentType   String      @map("document_type")
  fileName       String      @map("file_name")
  fileType       String?     @map("file_type")
  size           Int?
  dataUrl        String      @map("data_url") @db.Text
  remark         String?     @db.Text
  uploadedAt     DateTime    @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  uploadedById   String?     @map("uploaded_by_id") @db.Uuid
  uploadedBy     User?       @relation("EndorsementDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([endorsementId, documentType])
  @@index([uploadedById])
  @@map("endorsement_documents")
}

model Claim {
  id               String          @id @default(uuid()) @db.Uuid
  insuredName      String          @map("insured_name")
  mobileNo         String?         @map("mobile_no")
  contactPerson    String?         @map("contact_person")
  policyNo         String?         @map("policy_no")
  claimNo          String          @map("claim_no")
  groupName        String?         @map("group_name")
  claimDescription String?         @map("claim_description")
  claimDate        DateTime?       @map("claim_date") @db.Timestamptz(6)
  claimType        String          @default("Motor") @map("claim_type")
  claimStatus      String          @default("Open") @map("claim_status")
  followUpDate     DateTime?       @map("follow_up_date") @db.Timestamptz(6)
  currentRemark    String?         @map("current_remark")
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz(6)

  organizationId   String?         @map("organization_id") @db.Uuid
  organization     Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById      String?         @map("created_by_id") @db.Uuid
  createdBy        User?           @relation("ClaimCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?         @map("updated_by_id") @db.Uuid
  updatedBy        User?           @relation("ClaimUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById      String?         @map("deleted_by_id") @db.Uuid
  deletedBy        User?           @relation("ClaimDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  remarks          ClaimRemark[]
  documents        ClaimDocument[]

  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, claimStatus])
  @@index([organizationId, followUpDate])
  @@index([createdById, deletedAt, updatedAt])
  @@index([claimNo])
  @@index([mobileNo])
  @@map("claims")
}

model ClaimRemark {
  id             String    @id @default(uuid()) @db.Uuid
  claimId        String    @map("claim_id") @db.Uuid
  claim          Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  text           String    @db.Text
  followUpDate   DateTime? @map("follow_up_date") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById    String?   @map("created_by_id") @db.Uuid
  createdBy      User?     @relation("ClaimRemarkCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([claimId, createdAt])
  @@index([createdById])
  @@map("claim_remarks")
}

model ClaimDocument {
  id           String    @id @default(uuid()) @db.Uuid
  claimId      String    @map("claim_id") @db.Uuid
  claim        Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  name         String
  fileName     String    @map("file_name")
  fileType     String?   @map("file_type")
  size         Int?
  dataUrl      String    @map("data_url") @db.Text
  uploadedAt   DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  uploadedById String?   @map("uploaded_by_id") @db.Uuid
  uploadedBy   User?     @relation("ClaimDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([claimId, uploadedAt])
  @@index([uploadedById])
  @@map("claim_documents")
}

model BlogPost {
  id         String        @id @default(uuid()) @db.Uuid
  slug       String        @unique
  title      String
  excerpt    String        @db.Text
  category   String
  readTime   String        @map("read_time")
  date       DateTime      @db.Timestamptz(6)
  authorName String        @map("author_name")
  authorRole String        @map("author_role")
  coverImage String        @map("cover_image")
  published  Boolean       @default(true)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sections   BlogSection[]

  @@index([category])
  @@index([published, date])
  @@map("blog_posts")
}

model BlogSection {
  id         String   @id @default(uuid()) @db.Uuid
  blogPostId String   @map("blog_post_id") @db.Uuid
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  type       String
  text       String?  @db.Text
  items      Json?
  order      Int      @default(0)

  @@index([blogPostId, order])
  @@map("blog_sections")
}

model WhatsAppTemplate {
  id             String        @id @default(uuid()) @db.Uuid
