generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum UploadStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  REVIEW_REQUIRED
  APPROVED
  REJECTED
  FAILED
  ARCHIVED
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditSource {
  API
  USER_ACTION
  AI_PIPELINE
  SYSTEM
  AUTH
}

model Organization {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users         User[]
  policyRecords PolicyRecord[]
  uploadedFiles UploadedFile[]
  auditLogs     AuditLog[]
  customerProfiles CustomerProfile[]

  @@map("organizations")
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  action         String
  entityType     String        @map("entity_type")
  entityId       String?       @map("entity_id")
  severity       AuditSeverity @default(INFO)
  source         AuditSource   @default(USER_ACTION)
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  metadata       Json?
  userId         String?       @map("user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User?         @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model CustomerProfile {
  id                  String       @id @default(uuid()) @db.Uuid
  name                String
  phone               String
  alternatePhone      String?      @map("alternate_phone")
  email               String?
  address             String?
  city                String?
  state               String?
  occupation          String?
  businessType        String?      @map("business_type")
  contactPersonName   String?      @map("contact_person_name")
  customerType        String       @default("New") @map("customer_type")
  assignedTo          String?      @map("assigned_to")
  referenceSource     String?      @map("reference_source")
  sourcePolicyId      String?      @map("source_policy_id") @db.Uuid
  sourcePolicyNumber  String?      @map("source_policy_number")
  sourcePolicyType    String?      @map("source_policy_type")
  sourceCompany       String?      @map("source_company")
  selectedLOBs        Json         @default("[]") @map("selected_lobs")
  lobDetails          Json         @default("{}") @map("lob_details")
  status              String       @default("New Lead")
  followUpDate        DateTime?    @map("follow_up_date") @db.Timestamptz(6)
  lastFollowUpDate    DateTime?    @map("last_follow_up_date") @db.Timestamptz(6)
  nextFollowUpDate    DateTime?    @map("next_follow_up_date") @db.Timestamptz(6)
  followUpRemark      String?      @map("follow_up_remark")
  followUpOutcome     String?      @map("follow_up_outcome")
  remarks             String?
  convertedToCustomer Boolean      @default(false) @map("converted_to_customer")
  convertedPolicyId   String?      @map("converted_policy_id") @db.Uuid
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz(6)

  organizationId      String?      @map("organization_id") @db.Uuid
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById         String?      @map("created_by_id") @db.Uuid
  createdBy           User?        @relation("CustomerProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?      @map("updated_by_id") @db.Uuid
  updatedBy           User?        @relation("CustomerProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([sourcePolicyNumber])
  @@index([organizationId])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, status])
  @@index([organizationId, nextFollowUpDate])
  @@index([organizationId, createdAt])
  @@index([createdById, deletedAt, updatedAt])
  @@index([phone, deletedAt])
  @@index([status, deletedAt])
  @@index([createdById])
  @@index([deletedAt])
  @@map("customer_profiles")
}

model PolicyRecord {
  id                      String             @id @db.Uuid
  savedAt                 DateTime           @default(now()) @map("saved_at") @db.Timestamptz(6)
  data                    Json
  pdfBytes                Bytes?             @map("pdf_bytes")
  pdfFileName             String?            @map("pdf_file_name")
  pdfMimeType             String?            @map("pdf_mime_type")
  sourceFile              String?            @map("source_file")
  rawText                 String?            @map("raw_text")
  detectedCompany         String?            @map("detected_company")
  detectedServiceCategory String?            @map("detected_service_category")
  detectedPolicyType      String?            @map("detected_policy_type")
  selectedCompany         String?            @map("selected_company")
  detectedBankSource      String?            @map("detected_bank_source")
  selectedBankSource      String?            @map("selected_bank_source")
  selectedServiceCategory String?            @map("selected_service_category")
  selectedPolicyType      String?            @map("selected_policy_type")
  confidenceScore         Float?             @map("confidence_score")
  extractedData           Json?              @map("extracted_data")
  reviewedData            Json?              @map("reviewed_data")
  extractionMethod        String?            @map("extraction_method")
  extractionQuality       Json?              @map("extraction_quality")
  extractionLog           Json?              @map("extraction_log")
  schemaVersion           Int?               @map("schema_version")
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  uploadedFileId          String?            @map("uploaded_file_id") @db.Uuid
  uploadedFile            UploadedFile?      @relation(fields: [uploadedFileId], references: [id])
  policySchemaId          String?            @map("policy_schema_id") @db.Uuid
  policySchema            PolicySchema?      @relation(fields: [policySchemaId], references: [id])
  
  organizationId          String?            @map("organization_id") @db.Uuid
  organization            Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById             String?            @map("created_by_id") @db.Uuid
  createdBy               User?              @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById             String?            @map("updated_by_id") @db.Uuid
  updatedBy               User?              @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById             String?            @map("deleted_by_id") @db.Uuid
  deletedBy               User?              @relation("PolicyDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedAt               DateTime?          @map("deleted_at") @db.Timestamptz(6)

  renewalStatus           String?            @default("ACTIVE") @map("renewal_status")
  previousPolicyId        String?            @map("previous_policy_id") @db.Uuid
  renewedPolicyId         String?            @map("renewed_policy_id") @db.Uuid
  renewalDate             DateTime?          @map("renewal_date") @db.Timestamptz(6)
  lostReason              String?            @map("lost_reason")
  isActivePolicy          Boolean            @default(true) @map("is_active_policy")

  @@index([savedAt])
  @@index([uploadedFileId])
  @@index([policySchemaId])
  @@index([organizationId])
  @@index([organizationId, deletedAt, savedAt])
  @@index([organizationId, deletedAt, isActivePolicy])
  @@index([organizationId, renewalStatus])
  @@index([organizationId, isActivePolicy, renewalStatus])
  @@index([createdById, deletedAt, savedAt])
  @@index([selectedCompany])
  @@index([selectedPolicyType])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([createdById])
  @@map("pdf_records")
}

model BankSource {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique
  aliases   Json         @default("[]")
  active    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  schemas   PolicySchema[]
  uploads   UploadedFile[] @relation("DetectedBankSource")

  @@map("bank_sources")
}

model InsuranceCompany {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  aliases     Json         @default("[]")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  categories  PolicyType[]
  schemas     PolicySchema[]
  uploads     UploadedFile[] @relation("DetectedCompany")

  @@map("insurance_companies")
}

model ServiceCategory {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  aliases     Json         @default("[]")
  keywords    Json         @default("[]")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  policyTypes PolicyType[]
  schemas     PolicySchema[]
  uploads     UploadedFile[] @relation("DetectedCategory")

  @@map("service_categories")
}

model PolicyType {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  aliases            Json               @default("[]")
  keywords           Json               @default("[]")
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  insuranceCompanyId String?            @map("insurance_company_id") @db.Uuid
  serviceCategoryId  String             @map("service_category_id") @db.Uuid
  insuranceCompany   InsuranceCompany?  @relation(fields: [insuranceCompanyId], references: [id])
  serviceCategory    ServiceCategory    @relation(fields: [serviceCategoryId], references: [id])
  schemas            PolicySchema[]
  uploads            UploadedFile[]     @relation("DetectedPolicyType")

  @@unique([name, insuranceCompanyId, serviceCategoryId])
  @@map("policy_types")
}

model PolicySchema {
  id           String            @id @default(uuid()) @db.Uuid
  policyTypeId String            @map("policy_type_id") @db.Uuid
  bankSourceId String?           @map("bank_source_id") @db.Uuid
  insuranceCompanyId String?     @map("insurance_company_id") @db.Uuid
  serviceCategoryId String?      @map("service_category_id") @db.Uuid
  version      Int               @default(1)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  bankSource   BankSource?       @relation(fields: [bankSourceId], references: [id])
  insuranceCompany InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  serviceCategory ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  policyType   PolicyType        @relation(fields: [policyTypeId], references: [id])
  fields       FieldDefinition[]
  records      PolicyRecord[]

  @@unique([policyTypeId, version])
  @@map("policy_schemas")
}

model FieldDefinition {
  id             String       @id @default(uuid()) @db.Uuid
  policySchemaId String       @map("policy_schema_id") @db.Uuid
  key            String
  label          String
  fieldType      String       @map("field_type")
  required       Boolean      @default(false)
  options        Json         @default("[]")
  aliases        Json         @default("[]")
  regexPattern    String?      @map("regex_pattern")
  section         String?
  active          Boolean      @default(true)
  order          Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  policySchema   PolicySchema @relation(fields: [policySchemaId], references: [id], onDelete: Cascade)

  @@unique([policySchemaId, key])
  @@map("field_definitions")
}

model UploadedFile {
  id                         String             @id @default(uuid()) @db.Uuid
  sourceFile                 String             @map("source_file")
  mimeType                   String?            @map("mime_type")
  sizeBytes                  Int?               @map("size_bytes")
  pdfBytes                   Bytes?             @map("pdf_bytes")
  rawText                    String?            @map("raw_text")
  extractionMethod           String?            @map("extraction_method")
  status                     UploadStatus       @default(UPLOADED)
  detectedBankSourceId       String?            @map("detected_bank_source_id") @db.Uuid
  detectedCompanyId          String?            @map("detected_company_id") @db.Uuid
  detectedServiceCategoryId  String?            @map("detected_service_category_id") @db.Uuid
  detectedPolicyTypeId       String?            @map("detected_policy_type_id") @db.Uuid
  detectedBankSourceName     String?            @map("detected_bank_source_name")
  detectedCompanyName        String?            @map("detected_company_name")
  detectedServiceCategoryName String?           @map("detected_service_category_name")
  detectedPolicyTypeName     String?            @map("detected_policy_type_name")
  confidenceScore            Float?             @map("confidence_score")
  extractedData              Json?              @map("extracted_data")
  extractionQuality           Json?              @map("extraction_quality")
  extractionLog               Json?              @map("extraction_log")
  schemaFallbackLevel         String?            @map("schema_fallback_level")
  schemaVersion              Int?               @map("schema_version")
  errorMessage               String?            @map("error_message")
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  detectedBankSource         BankSource?        @relation("DetectedBankSource", fields: [detectedBankSourceId], references: [id])
  detectedCompany            InsuranceCompany?  @relation("DetectedCompany", fields: [detectedCompanyId], references: [id])
  detectedServiceCategory    ServiceCategory?   @relation("DetectedCategory", fields: [detectedServiceCategoryId], references: [id])
  detectedPolicyType         PolicyType?        @relation("DetectedPolicyType", fields: [detectedPolicyTypeId], references: [id])
  policyRecords              PolicyRecord[]
  
  organizationId             String?            @map("organization_id") @db.Uuid
  organization               Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdById                String?            @map("created_by_id") @db.Uuid
  createdBy                  User?              @relation("UploadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById                String?            @map("updated_by_id") @db.Uuid
  updatedBy                  User?              @relation("UploadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById                String?            @map("deleted_by_id") @db.Uuid
  deletedBy                  User?              @relation("UploadDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedAt                  DateTime?          @map("deleted_at") @db.Timestamptz(6)

  storageProvider            String?            @map("storage_provider")
  storagePath                String?            @map("storage_path")
  fileHash                   String?            @map("file_hash")
  checksum                   String?
  fileSize                   Int?               @map("file_size")
  storageMetadata            Json?              @map("storage_metadata")

  @@index([createdAt])
  @@index([status])
  @@index([organizationId])
  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([createdById, deletedAt, createdAt])
  @@index([deletedAt])
  @@index([createdById])
  @@map("uploaded_files")
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  password       String
  name           String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  role           UserRole       @default(AGENT)
  organizationId String?        @map("organization_id") @db.Uuid
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  
  createdPolicies PolicyRecord[] @relation("PolicyCreatedBy")
  updatedPolicies PolicyRecord[] @relation("PolicyUpdatedBy")
  deletedPolicies PolicyRecord[] @relation("PolicyDeletedBy")
  
  createdUploads UploadedFile[] @relation("UploadCreatedBy")
  updatedUploads UploadedFile[] @relation("UploadUpdatedBy")
  deletedUploads UploadedFile[] @relation("UploadDeletedBy")

  auditLogs      AuditLog[]
  createdCustomerProfiles CustomerProfile[] @relation("CustomerProfileCreatedBy")
  updatedCustomerProfiles CustomerProfile[] @relation("CustomerProfileUpdatedBy")

  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}
