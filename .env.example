DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Authentication
JWT_SECRET=

# AI extraction review. Prefer OpenAI in production; Groq remains a fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional Google Drive storage
STORAGE_PROVIDER=google_drive
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_MAKE_PUBLIC=false

# Follow-up notification emails
CRON_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BIMAHEADQUARTER <notifications@bimaheadquarter.com>"
