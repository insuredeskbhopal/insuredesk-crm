{
  "name": "policy-pdf-intake",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:setup": "node scripts/seed-master-data.cjs",
    "db:migrate-saas": "node scripts/migrate-saas.cjs",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "googleapis": "^173.0.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.468.0",
    "next": "^15.3.2",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.17.6",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "5.8.2",
    "vitest": "^4.1.7"
  }
}
